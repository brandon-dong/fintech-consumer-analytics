# Snowflake credentials — copy to .env and fill in values
# Never commit .env to git
# Format: <account-locator>.<region> e.g. xy12345.us-east-1
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=FINTECH_ANALYTICS
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=  # optional — uses default role if blank

# CFPB API (no key required — public API)
CFPB_API_BASE_URL=https://www.consumerfinance.gov/data-research/consumer-complaints/search/api/v1/
